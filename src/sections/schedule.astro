---
import "../styles/global.css";
import "../styles/index.css";

import { Image } from 'astro:assets'
import egypt_schedule from '/src/images/egypt_schedule.jpg'
import travel from '/src/images/travel.png'
import soonCome from '/src/images/soon_come.jpg'

---


<section data-hero class="relative min-h-screen">
	<div class="absolute min-h-screen w-full">
		<Image
			class="absolute inset-0 w-full h-full object-cover"
			src={egypt_schedule}
			alt=""
		/>
	</div>
	<div accommodation-header class="absolute inset-0 top-[5%] right-[5%] justify-right text-light-brown text-[7w] opacity-1 pl-3 pr-3">
		<h4 class="text-[clamp(1.5rem,2.5vw,8rem)] md:text-[clamp(2rem,2.5vw,8rem)] md:min-w-max text-right font-text">
				<a href="../#about-section" class="hover:text-button md:hover:italic">home</a> | <a href="../travel/#data-hero" class="hover:text-button md:hover:italic">accommodations </a>& <a href="../travel/#data-travel" class="hover:text-button md:hover:italic">travel</a> | <a href="../schedule" class="text-button hover:text-button md:hover:italic"><i>schedule</i> </a> | <a href="../FAQ" class="hover:text-button md:hover:italic">FAQ </a> | <a href="../registry" class="hover:text-button md:hover:italic">registry</a>
		</h4>
		<h1 class="text-right align-right text-[9vw] md:max-w-none whitespace-nowrap">SCHEDULE</h1>
	</div>
</section>

<section
  schedule-info
  class="flex bg-light-brown text-dark-brown min-h-screen w-full z-30 items-center justify-center"
>

<div class="max-w-[70vw] mx-auto p-8 sm:p-12 rounded-xl">
  

  <div class="mb-14">
    
    <h2 class="text-5xl font-semibold text-stone-800 tracking-widest uppercase border-stone-200 pb-3 mb-8">
      Friday, August 21
	  <p class="text-xl font-text text-stone-500 mt-1 leading-relaxed italic ">
            <a href="https://maps.app.goo.gl/Y1917wDQVyt79avD9">overbrook house</a>
		</p>
    </h2>
    

    <div class="space-y-6">
      
      <div class="flex flex-col text-3xl sm:flex-row sm:items-baseline gap-1 font-text sm:gap-8 border-stone-100 border-b pb-6">
        <div class="w-28 flex-shrink-0 text-stone-400 tracking-wide">
          6:30 pm
        </div>
        <div>
          <h4 class="font-semibold text-stone-700">welcome dinner <a class ="italic font-text font-medium">(optional)</a></h4>
          <p class="text-xl text-stone-500 mt-1 leading-relaxed italic ">
            semi-formal attire. for those who are in town and want to get <br>the party started early!
          </p>
        </div>
      </div>

      
    </div>
  </div>


  <div>
    
	<h2 class="text-5xl font-semibold text-stone-800 tracking-widest uppercase border-stone-200 pb-3 mb-8">
      Saturday, August 22
	  <p class="text-xl font-text text-stone-500 mt-1 leading-relaxed italic ">
            <a href="https://maps.app.goo.gl/Y1917wDQVyt79avD9">overbrook house</a>
		</p>
    </h2>
    
    <div class="space-y-6">
      
      <div class="flex flex-col text-3xl sm:flex-row sm:items-baseline gap-1 font-text sm:gap-8 border-stone-100 pb-6">
        <div class="w-28 flex-shrink-0 text-stone-400 tracking-wide">
          3:00 pm
        </div>
        <div>
          <h4 class="font-semibold text-stone-700">ceremony</h4>
		  <p class="text-xl text-stone-500 mt-1 leading-relaxed italic ">
            attire: western or Indian formal (see <a class="underline hover:text-button" href="https://www.pinterest.com/maddyaubey/sahil-and-maddy-guest-looks-inspo/?invite_code=e6e2dea4febb4dbdb26c2495a9fcf7b7&sender=463378386568387122">here</a> for inspiration)
          </p>
        </div>
      </div>

    
    <div class="space-y-6">
      

		<div class="flex flex-col text-3xl sm:flex-row sm:items-baseline gap-1 font-text sm:gap-8 border-stone-100 pb-6">
        <div class="w-28 flex-shrink-0 text-stone-400 tracking-wide">
          4:15 pm
        </div>
        <div>
          <h4 class="font-semibold text-stone-700">cocktail hour</h4>
        </div>
      </div>

    </div>

	<div class="space-y-6">
      

		<div class="flex flex-col text-3xl sm:flex-row sm:items-baseline gap-1 font-text sm:gap-8 border-stone-100 pb-6">
        <div class="w-28 flex-shrink-0 text-stone-400 tracking-wide">
          5:45 pm
        </div>
        <div>
          <h4 class="font-semibold text-stone-700">reception, dinner, and dancing</h4>
        </div>
      </div>

    </div>
  </div>

</div>

