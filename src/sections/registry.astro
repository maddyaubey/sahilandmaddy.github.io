---
import "../styles/global.css";
import "../styles/index.css";

import { Image } from 'astro:assets'
import banff from '/src/images/banff.jpg'
import soonCome from '/src/images/soon_come.jpg'
---

<section data-hero class="relative min-h-screen">
	<div class="absolute min-h-screen w-full">
		<Image
			class="absolute inset-0 w-full h-full object-cover"
			src={banff}
			alt=""
		/>
	</div>
	<div registry-header class="absolute inset-0 top-[5%] right-[5%] justify-right text-dark-blue text-[7w] opacity-1 pl-3 pr-3">
		<h4 class="text-[clamp(1.5rem,2.5vw,8rem)] md:text-[clamp(2rem,2.5vw,8rem)] md:min-w-max text-right font-text">
				<a href="../#about-section" class="hover:text-button md:hover:italic">home</a> | <a href="../travel/#data-hero" class="hover:text-button md:hover:italic">accommodations </a>& <a href="../travel/#data-travel" class="hover:text-button md:hover:italic">travel</a> | <a href="../schedule" class="hover:text-button md:hover:italic">schedule</a> | <a href="../FAQ" class="hover:text-button md:hover:italic">FAQ </a> | <a href="../registry" class="text-button italic hover:text-button md:hover:italic">registry</a>
		</h4>
		<h1 class="text-right align-right text-[9vw] md:max-w-none whitespace-nowrap">REGISTRY</h1>
	</div>
</section>

<section
  registry-info
  class="flex bg-dark-blue text-white min-h-screen w-full z-30 items-center justify-center"
>
<div class="pt-10 pb-10 justify-center text-center max-w-[70vw]">
